# Server Configuration
PORT=5000
NODE_ENV=development

# Security
JWT_SECRET="polda_jabar_super_secret_key_123456"

# Supabase Database (PostgreSQL)
# Ganti dengan "Transaction" connection string dari Supabase (pooler URL, biasanya berakhiran dengan pgbouncer / port 6543)
DATABASE_URL="postgresql://postgres.[PROYEK]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Ganti dengan "Session" connection string dari Supabase (direct connection URL, port 5432)
DIRECT_URL="postgresql://postgres.[PROYEK]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Supabase Storage Configuration
SUPABASE_URL="https://[PROYEK].supabase.co"
SUPABASE_ANON_KEY="ey..."
