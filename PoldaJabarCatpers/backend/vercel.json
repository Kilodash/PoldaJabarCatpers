{
  "version": 2,
  "regions": ["sin1"],
  "builds": [
    {
      "src": "src/server.js",
      "use": "@vercel/node"
    }
  ],
  "functions": {
    "src/server.js": {
      "maxDuration": 30,
      "includeFiles": "prisma/**"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "src/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "src/server.js"
    }
  ]
}
